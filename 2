#!/bin/bash

# ==========================================
# VPS 配置脚本
# ==========================================

# 颜色定义
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[36m'
C_WHITE='\033[1;37m' # 强制高亮纯白色，对抗 SSH 软件自带的变色
C_RESET='\033[0m'

# 检查是否为 root 用户
if [[ $EUID -ne 0 ]]; then
   echo -e "${C_RED}[错误] 必须使用 root 用户运行此脚本！${C_RESET}"
   exit 1
fi

# ================= 核心功能函数 =================

# 1. 更新环境
update_env() {
    echo -e "${C_GREEN}[开始] 正在更新系统并安装 sudo 与 curl...${C_RESET}"
    apt update -y && apt upgrade -y && apt install sudo curl wget -y
    echo -e "${C_GREEN}[完成] 基础环境配置完毕！${C_RESET}"
}

# 2. 网络体检
network_check() {
    echo -e "${C_CYAN}---------- 正在进行网络体检 ----------${C_RESET}"
    
    # 检查 IPv4
    ipv4=$(curl -s4m3 https://api.ipify.org)
    if [ -n "$ipv4" ]; then
        echo -e "IPv4 状态: ${C_GREEN}连通 (IP: $ipv4)${C_RESET}"
    else
        echo -e "IPv4 状态: ${C_RED}异常或未分配${C_RESET}"
    fi

    # 检查 IPv6
    ipv6=$(curl -s6m3 https://api64.ipify.org)
    if [ "$ipv6" != "$ipv4" ] && [ -n "$ipv6" ]; then
        echo -e "IPv6 状态: ${C_GREEN}连通 (IP: $ipv6)${C_RESET}"
    else
        echo -e "IPv6 状态: ${C_RED}异常或未分配${C_RESET}"
    fi

    # 检查 DNS 解析
    if ping -c 1 -w 3 baidu.com &>/dev/null || ping -c 1 -w 3 google.com &>/dev/null; then
        echo -e "DNS 解析:  ${C_GREEN}正常${C_RESET}"
    else
        echo -e "DNS 解析:  ${C_RED}异常 (无法解析域名)${C_RESET}"
    fi
    echo -e "${C_CYAN}--------------------------------------${C_RESET}"
}

# 3. 体检并自动修复
network_fix() {
    network_check
    echo -e "${C_YELLOW}[开始] 正在执行自动修复策略...${C_RESET}"
    
    cp /etc/resolv.conf /etc/resolv.conf.bak
    cat > /etc/resolv.conf <<EOF
nameserver 8.8.8.8
nameserver 1.1.1.1
nameserver 2001:4860:4860::8888
EOF
    
    iptables -P INPUT ACCEPT
    iptables -P FORWARD ACCEPT
    iptables -P OUTPUT ACCEPT
    
    echo -e "${C_GREEN}[完成] DNS 已重置为公共 DNS，防火墙规则已放行。${C_RESET}"
    echo -e "${C_CYAN}---------- 修复后网络状态 ----------${C_RESET}"
    network_check
}

# 4. 开启 IPv6
enable_ipv6() {
    echo -e "${C_YELLOW}[开始] 正在开启 IPv6...${C_RESET}"
    sed -i '/net.ipv6.conf.all.disable_ipv6/d' /etc/sysctl.conf
    sed -i '/net.ipv6.conf.default.disable_ipv6/d' /etc/sysctl.conf
    sed -i '/net.ipv6.conf.lo.disable_ipv6/d' /etc/sysctl.conf
    
    echo "net.ipv6.conf.all.disable_ipv6 = 0" >> /etc/sysctl.conf
    echo "net.ipv6.conf.default.disable_ipv6 = 0" >> /etc/sysctl.conf
    echo "net.ipv6.conf.lo.disable_ipv6 = 0" >> /etc/sysctl.conf
    
    sysctl -p &>/dev/null
    echo -e "${C_GREEN}[完成] IPv6 已开启！${C_RESET}"
}

# 5. 关闭 IPv6
disable_ipv6() {
    echo -e "${C_YELLOW}[开始] 正在关闭 IPv6...${C_RESET}"
    sed -i '/net.ipv6.conf.all.disable_ipv6/d' /etc/sysctl.conf
    sed -i '/net.ipv6.conf.default.disable_ipv6/d' /etc/sysctl.conf
    sed -i '/net.ipv6.conf.lo.disable_ipv6/d' /etc/sysctl.conf
    
    echo "net.ipv6.conf.all.disable_ipv6 = 1" >> /etc/sysctl.conf
    echo "net.ipv6.conf.default.disable_ipv6 = 1" >> /etc/sysctl.conf
    echo "net.ipv6.conf.lo.disable_ipv6 = 1" >> /etc/sysctl.conf
    
    sysctl -p &>/dev/null
    echo -e "${C_GREEN}[完成] IPv6 已关闭！${C_RESET}"
}

# 6. TCP 通用调优
tcp_tune() {
    echo -e "${C_YELLOW}[开始] 正在进行 TCP 网络调优 (BBR加速)...${C_RESET}"
    sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
    
    echo "net.core.default_qdisc = fq" >> /etc/sysctl.conf
    echo "net.ipv4.tcp_congestion_control = bbr" >> /etc/sysctl.conf
    
    sysctl -p &>/dev/null
    
    bbr_status=$(lsmod | grep bbr)
    if [ -n "$bbr_status" ]; then
        echo -e "${C_GREEN}[完成] BBR 拥塞控制已成功开启！${C_RESET}"
    else
        echo -e "${C_RED}[提示] BBR 开启可能需要重启 VPS (输入 reboot) 生效。${C_RESET}"
    fi
}

# 7. 设置时区为中国
set_timezone() {
    echo -e "${C_YELLOW}[开始] 正在设置时区为 中国/上海...${C_RESET}"
    rm -rf /etc/localtime
    ln -s /usr/share/zoneinfo/Asia/Shanghai /etc/localtime
    echo "Asia/Shanghai" > /etc/timezone
    echo -e "${C_GREEN}[完成] 当前系统时间: $(date)${C_RESET}"
}

# 8. IP 质量检测
ip_quality_check() {
    echo -e "${C_YELLOW}[开始] 正在执行 IP 质量检测...${C_RESET}"
    bash <(curl -Ls https://IP.Check.Place) -y
    echo -e "${C_GREEN}[完成] IP 质量检测执行完毕！${C_RESET}"
}

# 9. 网络质量检测
network_quality_check() {
    echo -e "${C_YELLOW}[开始] 正在执行网络质量检测...${C_RESET}"
    bash <(curl -Ls https://Net.Check.Place) -y
    echo -e "${C_GREEN}[完成] 网络质量检测执行完毕！${C_RESET}"
}

# 10. 流媒体检测
streaming_media_check() {
    echo -e "${C_YELLOW}[开始] 正在执行流媒体解锁检测...${C_RESET}"
    bash <(curl -L -s https://github.com/1-stream/RegionRestrictionCheck/raw/main/check.sh)
    echo -e "${C_GREEN}[完成] 流媒体检测执行完毕！${C_RESET}"
}

# ================= 菜单系统 =================

show_menu() {
    echo -ne "\033[0m"
    clear
    
    echo -e "${C_CYAN}=========================================================${C_RESET}"
    echo -e "                   ${C_GREEN}VPS 配置脚本${C_RESET}                   "
    echo -e "${C_CYAN}=========================================================${C_RESET}"
    
    # 给每一行描述强制加上 ${C_WHITE}，无论客户端怎么识别都会是白色
    echo -e "${C_YELLOW}  1.${C_WHITE} 更新系统并安装环境 (apt update & curl)${C_RESET}"
    echo -e "${C_YELLOW}  2.${C_WHITE} 网络体检 (检查 IPv4/IPv6 及 DNS)${C_RESET}"
    echo -e "${C_YELLOW}  3.${C_WHITE} 体检 + 自动修复网络${C_RESET}"
    echo -e "${C_YELLOW}  4.${C_WHITE} 开启 IPV6${C_RESET}"
    echo -e "${C_YELLOW}  5.${C_WHITE} 关闭 IPV6${C_RESET}"
    echo -e "${C_YELLOW}  6.${C_WHITE} TCP 通用调优 (一键开启 BBR 加速)${C_RESET}"
    echo -e "${C_YELLOW}  7.${C_WHITE} 设置系统时区为中国 (Asia/Shanghai)${C_RESET}"
    echo -e "${C_YELLOW}  8.${C_WHITE} IP 质量检测 (IP.Check.Place)${C_RESET}"
    echo -e "${C_YELLOW}  9.${C_WHITE} 网络质量检测 (Net.Check.Place)${C_RESET}"
    echo -e "${C_YELLOW} 10.${C_WHITE} 流媒体检测 (RegionRestrictionCheck)${C_RESET}"
    echo -e "${C_RED}  0.${C_WHITE} 退出脚本${C_RESET}"
    echo -e "${C_CYAN}=========================================================${C_RESET}"
    
    echo -ne "${C_WHITE}请输入对应数字并按回车: ${C_RESET}"
}

while true; do
    show_menu
    read choice
    echo ""
    
    echo -ne "\033[0m"
    
    case $choice in
        1) update_env ;;
        2) network_check ;;
        3) network_fix ;;
        4) enable_ipv6 ;;
        5) disable_ipv6 ;;
        6) tcp_tune ;;
        7) set_timezone ;;
        8) ip_quality_check ;;
        9) network_quality_check ;;
        10) streaming_media_check ;;
        0)
            echo -e "${C_RED}[退出] 感谢使用，再见！${C_RESET}"
            exit 0
            ;;
        *)
            echo -e "${C_RED}[错误] 无效的输入，请重新输入数字！${C_RESET}"
            ;;
    esac
    
    echo ""
    echo -ne "${C_WHITE}按回车键返回主菜单...${C_RESET}"
    read -r
done
