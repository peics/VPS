#!/bin/bash

# ==========================================
# VPS 配置脚本
# ==========================================

# 颜色定义
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[36m'
C_WHITE='\033[1;37m' # 强制高亮纯白色，对抗 SSH 软件自带的变色
C_RESET='\033[0m'

# 检查是否为 root 用户
if [[ $EUID -ne 0 ]]; then
echo -e "${C_RED}[错误] 必须使用 root 用户运行此脚本！${C_RESET}"
exit 1
fi

# ================= 核心功能函数 =================

# 1. 更新环境
update_env() {
echo -e "${C_GREEN}[开始] 正在更新系统并安装 sudo 与 curl...${C_RESET}"
apt update -y && apt upgrade -y && apt install sudo curl wget -y
echo -e "${C_GREEN}[完成] 基础环境配置完毕！${C_RESET}"
}

# 2. 安装常用指令工具
install_common_tools() {
echo -e "${C_YELLOW}[开始] 正在安装常用指令工具 (bash, curl, wget, vim, git, unzip, tar 等)...${C_RESET}"
apt update -y
apt install -y bash curl wget vim git unzip tar jq dnsutils net-tools
echo -e "${C_GREEN}[完成] 常用指令工具安装完毕！${C_RESET}"
}

# 3. 网络体检
network_check() {
echo -e "${C_CYAN}---------- 正在进行网络体检 ----------${C_RESET}"
# 检查 IPv4
ipv4=$(curl -s4m3 https://api.ipify.org)
if [ -n "$ipv4" ]; then
echo -e "IPv4 状态: ${C_GREEN}连通 (IP: $ipv4)${C_RESET}"
else
echo -e "IPv4 状态: ${C_RED}异常或未分配${C_RESET}"
fi

# 检查 IPv6
ipv6=$(curl -s6m3 https://api64.ipify.org)
if [ "$ipv6" != "$ipv4" ] && [ -n "$ipv6" ]; then
echo -e "IPv6 状态: ${C_GREEN}连通 (IP: $ipv6)${C_RESET}"
else
echo -e "IPv6 状态: ${C_RED}异常或未分配${C_RESET}"
fi

# 检查 DNS 解析
if ping -c 1 -w 3 baidu.com &>/dev/null || ping -c 1 -w 3 google.com &>/dev/null; then
echo -e "DNS 解析: ${C_GREEN}正常${C_RESET}"
else
echo -e "DNS 解析: ${C_RED}异常 (无法解析域名)${C_RESET}"
fi
echo -e "${C_CYAN}--------------------------------------${C_RESET}"
}

# 4. 体检并自动修复
network_fix() {
network_check
echo -e "${C_YELLOW}[开始] 正在执行自动修复策略...${C_RESET}"
cp /etc/resolv.conf /etc/resolv.conf.bak
cat > /etc/resolv.conf <<EOF
nameserver 8.8.8.8
nameserver 1.1.1.1
nameserver 2001:4860:4860::8888
EOF
iptables -P INPUT ACCEPT
iptables -P FORWARD ACCEPT
iptables -P OUTPUT ACCEPT
echo -e "${C_GREEN}[完成] DNS 已重置为公共 DNS，防火墙规则已放行。${C_RESET}"
echo -e "${C_CYAN}---------- 修复后网络状态 ----------${C_RESET}"
network_check
}

# 5. 开启 IPv6
enable_ipv6() {
echo -e "${C_YELLOW}[开始] 正在开启 IPv6...${C_RESET}"
sed -i '/net.ipv6.conf.all.disable_ipv6/d' /etc/sysctl.conf
sed -i '/net.ipv6.conf.default.disable_ipv6/d' /etc/sysctl.conf
sed -i '/net.ipv6.conf.lo.disable_ipv6/d' /etc/sysctl.conf
echo "net.ipv6.conf.all.disable_ipv6 = 0" >> /etc/sysctl.conf
echo "net.ipv6.conf.default.disable_ipv6 = 0" >> /etc/sysctl.conf
echo "net.ipv6.conf.lo.disable_ipv6 = 0" >> /etc/sysctl.conf
sysctl -p &>/dev/null
echo -e "${C_GREEN}[完成] IPv6 已开启！${C_RESET}"
}

# 6. 关闭 IPv6
disable_ipv6() {
echo -e "${C_YELLOW}[开始] 正在关闭 IPv6...${C_RESET}"
sed -i '/net.ipv6.conf.all.disable_ipv6/d' /etc/sys
