#!/bin/bash

# ==========================================
# VPS 配置脚本
# ==========================================

# 颜色定义
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[36m'
C_WHITE='\033[1;37m' # 强制高亮纯白色，对抗 SSH 软件自带的变色
C_RESET='\033[0m'

# 检查是否为 root 用户
if [[ $EUID -ne 0 ]]; then
    echo -e "${C_RED}[错误] 必须使用 root 用户运行此脚本！${C_RESET}"
    exit 1
fi

# ================= 核心功能函数 =================

# 1. 更新环境
update_env() {
    echo -e "${C_GREEN}[开始] 正在更新系统并安装 sudo 与 curl...${C_RESET}"
    apt update -y && apt upgrade -y && apt install sudo curl wget -y
    echo -e "${C_GREEN}[完成] 基础环境配置完毕！${C_RESET}"
}

# 2. 安装常用指令工具
install_common_tools() {
    echo -e "${C_YELLOW}[开始] 正在安装常用指令工具 (bash, curl, wget, vim, git, unzip, tar 等)...${C_RESET}"
    apt update -y
    apt install -y bash curl wget vim git unzip tar jq dnsutils net-tools
    echo -e "${C_GREEN}[完成] 常用指令工具安装完毕！${C_RESET}"
}

# 3. 网络体检
network_check() {
    echo -e "${C_CYAN}---------- 正在进行网络体检 ----------${C_RESET}"
    # 检查 IPv4
    ipv4=$(curl -s4m3 https://api.ipify.org)
    if [ -n "$ipv4" ]; then
        echo -e "IPv4 状态: ${C_GREEN}连通 (IP: $ipv4)${C_RESET}"
    else
        echo -e "IPv4 状态: ${C_RED}异常或未分配${C_RESET}"
    fi

    # 检查 IPv6
    ipv6=$(curl -s6m3 https://api64.ipify.org)
    if [ "$ipv6" != "$ipv4" ] && [ -n "$ipv6" ]; then
        echo -e "IPv6 状态: ${C_GREEN}连通 (IP: $ipv6)${C_RESET}"
    else
        echo -e "IPv6 状态: ${C_RED}异常或未分配${C_RESET}"
    fi

    # 检查 DNS 解析
    if ping -c 1 -w 3 baidu.com &>/dev/null || ping -c 1 -w 3 google.com &>/dev/null; then
        echo -e "DNS 解析: ${C_GREEN}正常${C_RESET}"
    else
        echo -e "DNS 解析: ${C_RED}异常 (无法解析域名)${C_RESET}"
    fi
    echo -e "${C_CYAN}--------------------------------------${C_RESET}"
}

# 4. 体检并自动修复
network_fix() {
    network_check
    echo -e "${C_YELLOW}[开始] 正在执行自动修复策略...${C_RESET}"
    cp /etc/resolv.conf /etc/resolv.conf.bak
    cat > /etc/resolv.conf <<EOF
nameserver 8.8.8.8
nameserver 1.1.1.1
nameserver 2001:4860:4860::8888
EOF
    iptables -P INPUT ACCEPT
    iptables -P FORWARD ACCEPT
    iptables -P OUTPUT ACCEPT
    echo -e "${C_GREEN}[完成] DNS 已重置为公共 DNS，防火墙规则已放行。${C_RESET}"
    echo -e "${C_CYAN}---------- 修复后网络状态 ----------${C_RESET}"
    network_check
}

# 5. 开启 IPv6
enable_ipv6() {
    echo -e "${C_YELLOW}[开始] 正在开启 IPv6...${C_RESET}"
    sed -i '/net.ipv6.conf.all.disable_ipv6/d' /etc/sysctl.conf
    sed -i '/net.ipv6.conf.default.disable_ipv6/d' /etc/sysctl.conf
    sed -i '/net.ipv6.conf.lo.disable_ipv6/d' /etc/sysctl.conf
    echo "net.ipv6.conf.all.disable_ipv6 = 0" >> /etc/sysctl.conf
    echo "net.ipv6.conf.default.disable_ipv6 = 0" >> /etc/sysctl.conf
    echo "net.ipv6.conf.lo.disable_ipv6 = 0" >> /etc/sysctl.conf
    sysctl -p &>/dev/null
    echo -e "${C_GREEN}[完成] IPv6 已开启！${C_RESET}"
}

# 6. 关闭 IPv6
disable_ipv6() {
    echo -e "${C_YELLOW}[开始] 正在关闭 IPv6...${C_RESET}"
    sed -i '/net.ipv6.conf.all.disable_ipv6/d' /etc/sysctl.conf
    sed -i '/net.ipv6.conf.default.disable_ipv6/d' /etc/sysctl.conf
    sed -i '/net.ipv6.conf.lo.disable_ipv6/d' /etc/sysctl.conf
    echo "net.ipv6.conf.all.disable_ipv6 = 1" >> /etc/sysctl.conf
    echo "net.ipv6.conf.default.disable_ipv6 = 1" >> /etc/sysctl.conf
    echo "net.ipv6.conf.lo.disable_ipv6 = 1" >> /etc/sysctl.conf
    sysctl -p &>/dev/null
    echo -e "${C_GREEN}[完成] IPv6 已关闭！${C_RESET}"
}

# 7. TCP 通用调优
tcp_tune() {
    echo -e "${C_YELLOW}[开始] 正在进行 TCP 网络调优 (BBR加速)...${C_RESET}"
    sed -i '/net.core.default_qdisc/d' /etc/sysctl.conf
    sed -i '/net.ipv4.tcp_congestion_control/d' /etc/sysctl.conf
    echo "net.core.default_qdisc = fq" >> /etc/sysctl.conf
    echo "net.ipv4.tcp_congestion_control = bbr" >> /etc/sysctl.conf
    sysctl -p &>/dev/null
    bbr_status=$(lsmod | grep bbr)
    if [ -n "$bbr_status" ]; then
        echo -e "${C_GREEN}[完成] BBR 拥塞控制已成功开启！${C_RESET}"
    else
        echo -e "${C_RED}[提示] BBR 开启可能需要重启 VPS (输入 reboot) 生效。${C_RESET}"
    fi
}

# 8. 设置时区为中国
set_timezone() {
    echo -e "${C_YELLOW}[开始] 正在设置时区为 中国/上海...${C_RESET}"
    rm -rf /etc/localtime
    ln -s /usr/share/zoneinfo/Asia/Shanghai /etc/localtime
    echo "Asia/Shanghai" > /etc/timezone
    echo -e "${C_GREEN}[完成] 当前系统时间: $(date)${C_RESET}"
}

# 9. IP 质量检测
ip_quality_check() {
    echo -e "${C_YELLOW}[开始] 正在执行 IP 质量检测...${C_RESET}"
    bash <(curl -Ls https://IP.Check.Place) -y
    echo -e "${C_GREEN}[完成] IP 质量检测执行完毕！${C_RESET}"
}

# 10. 流媒体检测
streaming_media_check() {
    echo -e "${C_YELLOW}[开始] 正在执行流媒体解锁检测...${C_RESET}"
    bash <(curl -L -s https://github.com/1-stream/RegionRestrictionCheck/raw/main/check.sh)
    echo -e "${C_GREEN}[完成] 流媒体检测执行完毕！${C_RESET}"
}

# 11. 网络质量检测
network_quality_check() {
    echo -e "${C_YELLOW}[开始] 正在执行网络质量检测...${C_RESET}"
    bash <(curl -Ls https://Net.Check.Place) -y
    echo -e "${C_GREEN}[完成] 网络质量检测执行完毕！${C_RESET}"
}

# 12. Iperf3 安装
install_iperf3() {
    echo -e "${C_YELLOW}[开始] 正在安装 Iperf3...${C_RESET}"
    sudo apt-get update -y
    sudo apt-get install iperf3 -y
    echo -e "${C_GREEN}[完成] Iperf3 安装完毕！${C_RESET}"
}

# 13. Iperf3 运行
run_iperf3() {
    echo -e "${C_YELLOW}[开始] 正在运行 Iperf3 服务端模式...${C_RESET}"
    echo -e "${C_CYAN}[提示] 测速完成后，请按 Ctrl + C 结束并返回菜单。${C_RESET}"
    iperf3 -s
    echo -e "\n${C_GREEN}[完成] Iperf3 已结束运行。${C_RESET}"
}

# 14. 停用 Iperf3
stop_iperf3() {
    echo -e "${C_YELLOW}[开始] 正在停用 Iperf3 后台服务...${C_RESET}"
    sudo systemctl stop iperf3
    sudo systemctl disable iperf3
    pkill iperf3 &>/dev/null
    echo -e "${C_GREEN}[完成] Iperf3 已停止并禁用！${C_RESET}"
}

# 15. 安装 Gost SOCKS5 代理
setup_gost_socks5() {
    echo -e "${C_YELLOW}[开始] 正在配置 Gost SOCKS5 代理...${C_RESET}"
    
    # 检查并安装架构对应的二进制
    arch=$(uname -m)
    case $arch in
        x86_64) gost_arch="amd64" ;;
        aarch64) gost_arch="arm8" ;;
        *) echo -e "${C_RED}[错误] 不支持的架构: $arch${C_RESET}"; return 1 ;;
    esac

    if [ ! -f "/usr/local/bin/gost" ]; then
        echo -e "${C_CYAN}正在下载 Gost 二进制文件...${C_RESET}"
        # 使用官方 v2.11.5 稳定版
        wget -qO- https://github.com/ginuerzh/gost/releases/download/v2.11.5/gost-linux-${gost_arch}-2.11.5.gz | gzip -d > /usr/local/bin/gost
        chmod +x /usr/local/bin/gost
    fi

    # 获取用户输入
    echo -e "${C_WHITE}请输入 SOCKS5 代理配置信息：${C_RESET}"
    read -p "请输入用户名 (User): " gost_user
    read -p "请输入密码 (Password): " gost_pass
    read -p "请输入端口 (Port, 默认 1315): " gost_port
    gost_port=${gost_port:-1315}

    # 停止旧服务
    systemctl stop gost &>/dev/null

    # 创建 Systemd 持久化运行配置
    cat > /etc/systemd/system/gost.service <<EOF
[Unit]
Description=Gost SOCKS5 Proxy Service
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/gost -L socks5://${gost_user}:${gost_pass}@:${gost_port}
Restart=always

[Install]
WantedBy=multi-user.target
EOF

    # 启动并检查
    systemctl daemon-reload
    systemctl enable gost &>/dev/null
    systemctl start gost

    sleep 2
    if systemctl is-active --quiet gost; then
        echo -e "\n${C_GREEN}=========================================================${C_RESET}"
        echo -e "               Gost SOCKS5 代理安装成功！"
        echo -e "${C_GREEN}=========================================================${C_RESET}"
        echo -e "运行状态: ${C_GREEN}OK${C_RESET}"
        echo -e "用户名  : ${C_CYAN}${gost_user}${C_RESET}"
        echo -e "密码    : ${C_CYAN}${gost_pass}${C_RESET}"
        echo -e "端口    : ${C_CYAN}${gost_port}${C_RESET}"
        echo -e "连接地址: ${C_CYAN}$(curl -s4 api.ipify.org):${gost_port}${C_RESET}"
        echo -e "${C_GREEN}=========================================================${C_RESET}"
    else
        echo -e "${C_RED}[错误] Gost 服务未能正常启动，请检查端口是否被占用。${C_RESET}"
    fi
}

# ================= 菜单系统 =================

show_menu() {
    echo -ne "\033[0m"
    clear
    echo -e "${C_CYAN}=========================================================${C_RESET}"
    echo -e "                      ${C_GREEN}VPS 配置脚本${C_RESET}"
    echo -e "${C_CYAN}=========================================================${C_RESET}"
    echo -e "${C_YELLOW} 1.${C_WHITE} 更新系统并安装环境 (apt update & curl)${C_RESET}"
    echo -e "${C_YELLOW} 2.${C_WHITE} 安装常用指令工具 (bash, curl, wget, vim, git 等)${C_RESET}"
    echo -e "${C_YELLOW} 3.${C_WHITE} 网络体检 (检查 IPv4/IPv6 及 DNS)${C_RESET}"
    echo -e "${C_YELLOW} 4.${C_WHITE} 体检 + 自动修复网络${C_RESET}"
    echo -e "${C_YELLOW} 5.${C_WHITE} 开启 IPV6${C_RESET}"
    echo -e "${C_YELLOW} 6.${C_WHITE} 关闭 IPV6${C_RESET}"
    echo -e "${C_YELLOW} 7.${C_WHITE} TCP 通用调优 (一键开启 BBR 加速)${C_RESET}"
    echo -e "${C_YELLOW} 8.${C_WHITE} 设置系统时区为中国 (Asia/Shanghai)${C_RESET}"
    echo -e "${C_YELLOW} 9.${C_WHITE} IP 质量检测${C_RESET}"
    echo -e "${C_YELLOW} 10.${C_WHITE} 流媒体检测${C_RESET}"
    echo -e "${C_YELLOW} 11.${C_WHITE} 网络质量检测${C_RESET}"
    echo -e "${C_YELLOW} 12.${C_WHITE} Iperf3 安装${C_RESET}"
    echo -e "${C_YELLOW} 13.${C_WHITE} Iperf3 运行${C_RESET}"
    echo -e "${C_YELLOW} 14.${C_WHITE} 停用 Iperf3${C_RESET}"
    echo -e "${C_YELLOW} 15.${C_WHITE} 安装 Gost SOCKS5 代理 (持久化后台运行)${C_RESET}"
    echo -e "${C_RED} 0.${C_WHITE} 退出脚本${C_RESET}"
    echo -e "${C_CYAN}=========================================================${C_RESET}"
    echo -ne "${C_WHITE}请输入对应数字并按回车: ${C_RESET}"
}

while true; do
    show_menu
    read choice
    echo ""
    echo -ne "\033[0m"
    case $choice in
        1) update_env ;;
        2) install_common_tools ;;
        3) network_check ;;
        4) network_fix ;;
        5) enable_ipv6 ;;
        6) disable_ipv6 ;;
        7) tcp_tune ;;
        8) set_timezone ;;
        9) ip_quality_check ;;
        10) streaming_media_check ;;
        11) network_quality_check ;;
        12) install_iperf3 ;;
        13) run_iperf3 ;;
        14) stop_iperf3 ;;
        15) setup_gost_socks5 ;;
        0)
            echo -e "${C_GREEN}[退出] 正在清理操作痕迹并退出...${C_RESET}"
            clear
            history -c
            cat /dev/null > ~/.bash_history
            history -w
            exit 0
            ;;
        *)
            echo -e "${C_RED}[错误] 无效的输入，请重新输入数字！${C_RESET}"
            ;;
    esac
    echo ""
    echo -ne "${C_WHITE}按回车键返回主菜单...${C_RESET}"
    read -r
done
