#!/bin/bash

# ==========================================
# VPS 综合初始化与工具箱
# ==========================================

REMOTE_SCRIPT="https://box.dmitstock.com"

# 清理屏幕并显示菜单
show_menu() {
    clear
    echo -e "\033[36m=========================================================\033[0m"
    echo -e "\033[1;32m                  VPS 综合快捷配置脚本                   \033[0m"
    echo -e "\033[36m=========================================================\033[0m"
    echo -e "\033[1;33m  1.\033[0m 更新系统并安装环境 (apt update & upgrade & curl)"
    echo -e "\033[1;33m  2.\033[0m 执行原 DMIT 脚本 - 选项 1"
    echo -e "\033[1;33m  3.\033[0m 执行原 DMIT 脚本 - 选项 2"
    echo -e "\033[1;33m  4.\033[0m 执行原 DMIT 脚本 - 选项 3"
    echo -e "\033[1;33m  5.\033[0m 执行原 DMIT 脚本 - 选项 4"
    echo -e "\033[1;33m 12.\033[0m 执行原 DMIT 脚本 - 选项 12"
    echo -e "\033[1;33m 17.\033[0m 执行原 DMIT 脚本 - 选项 17"
    echo -e "\033[1;31m  0.\033[0m 退出脚本"
    echo -e "\033[36m=========================================================\033[0m"
}

# 自动执行远程脚本的函数
run_remote_option() {
    local option=$1
    echo -e "\033[1;32m[开始] 正在调用远程脚本并自动选择选项 ${option}...\033[0m"
    
    # 通过管道将对应数字直接传给远程交互脚本
    echo "${option}" | bash <(curl -fsSL ${REMOTE_SCRIPT})
    
    echo -e "\033[1;32m[完成] 该模块执行完毕！\033[0m"
    read -n 1 -s -r -p "按任意键返回主菜单..."
}

# 循环显示菜单并处理用户输入
while true; do
    show_menu
    read -p "请输入对应数字并按回车: " choice
    case $choice in
        1)
            echo -e "\033[1;32m[开始] 更新系统并安装 sudo 与 curl...\033[0m"
            apt update -y && apt upgrade -y && apt install sudo curl -y
            echo -e "\033[1;32m[完成] 基础环境配置完毕！\033[0m"
            read -n 1 -s -r -p "按任意键返回主菜单..."
            ;;
        2) run_remote_option "1" ;;
        3) run_remote_option "2" ;;
        4) run_remote_option "3" ;;
        5) run_remote_option "4" ;;
        12) run_remote_option "12" ;;
        17) run_remote_option "17" ;;
        0)
            echo -e "\033[1;31m[退出] 感谢使用，再见！\033[0m"
            exit 0
            ;;
        *)
            echo -e "\033[1;31m[错误] 无效的输入，请重新输入数字！\033[0m"
            sleep 2
            ;;
    esac
done
